# ─────────────────────────────────────────────────
# Aether Capsule — Environment Configuration
# Copy this file to .env and fill in your values.
# Keep this file in source control; never commit real secrets.
# ─────────────────────────────────────────────────

# SMTP (email) settings
# Example uses Gmail SMTP with an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your_smtp_app_password_here

# Supabase / PostgreSQL connection
# Get the full connection string from your Supabase project (Settings → Database)
# Example format (do NOT use these example credentials):
# postgresql://<db_user>:<db_pass>@<host>:<port>/<db_name>?sslmode=require
DATABASE_URL=postgresql://user:password@host:6543/postgres?sslmode=require

# Supabase client keys (optional; used only if you integrate direct Supabase client calls)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXX
SUPABASE_SECRET_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXX

# App settings
# APP_ENV choices: development | production
APP_ENV=production
# Used for any session/signing needs (keep secret in production)
SECRET_KEY=change_this_to_a_long_random_string

# Optional: tune DB connection timeout/pools (example)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
